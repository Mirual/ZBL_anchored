# ---------------------------------------------------------------------------
# ZBL_anchored — external resource configuration (example)
#
# Every machine-specific path in this repo is read from an environment variable,
# so NO personal absolute paths live in the source tree. Copy this file to
# `config.env`, fill in the paths for YOUR machine, then
#     source config.env
# before running any script. `config.env` is git-ignored.
#
# You only need to set the variables for the parts you actually run (see each
# sub-directory's README). Foundation model weights and datasets are NOT shipped
# with this repository — supply your own.
# ---------------------------------------------------------------------------

# ===== Foundation model weights (user-supplied) ============================
export ZBL_MACE_MH0="/path/to/mace-mh-0.model"          # MACE-MH-0 base (anchor core)
export ZBL_MACE_MH1="/path/to/mace-mh-1.model"          # MACE-MH-1 (LAMMPS / benchmarks)
export ZBL_MACE_ZBL_MODEL="/path/to/mace-zbl.model"     # ZBL-fine-tuned MACE (mace_zbl_training output)
export ZBL_DPA_MODEL="/path/to/dpa-3.1-3m-ft.pth"       # DPA-3.1 frozen checkpoint
export ZBL_DPA_MODEL_BORDEROP="/path/to/dpa-3.1-3m-ft-borderop.pth"  # DPA re-frozen for LAMMPS native pair_style
export ZBL_DPA_ZBL_INIT="/path/to/dpa-3.1-3m-ft-zbl-init.pth"        # DPA ZBL-initialised variant (dpa_variant/)
export ZBL_DPA_FT_MIX="/path/to/dpa31_ft_mix_e0pbe86.pth"           # DPA fine-tune (mixed) — comparison baseline
export ZBL_DPA_FT_USER="/path/to/dpa31_ft_user_only.pth"           # DPA fine-tune (user-only) — comparison baseline

# ===== Generated method artifacts (produced by scripts in this repo) =======
export ZBL_ANCHOR_RESULTS="/path/to/anchor/results"     # rnd.pt, rho_reference.npz, dimer tables
export ZBL_DIMER_PKL="/path/to/dimer_packed.pkl"        # packed dimer table (figures/make_zones_figure.py)
export ZBL_ANCHOR_WS="/path/to/idea_uncertainty_gated_physics_anchor"  # anchor workspace root (some scripts import siblings)

# ===== Evaluation datasets & system sets (user-supplied) ===================
export ZBL_EVAL_DATA="/path/to/vasp_eval/preflight"     # holds splits/keep_test.xyz, splits/u200_test.xyz
export ZBL_MPTRJ_XYZ="/path/to/mptrj_stratified_10k.xyz"  # in-distribution reference bank (extxyz)
export ZBL_MIXED_DATA="/path/to/mixed_dataset/data"     # mixed train/eval set (a few scripts)
export ZBL_HIGHP_SYSTEMS="/path/to/highP_systems"       # high-pressure test systems (anchor/scripts/extended_highP.py)
export ZBL_PKA_SYSTEMS="/path/to/pka_systems"           # PKA / recoil test systems (anchor/scripts/pka_radiation.py)
export ZBL_VASP_TIER1_WS="/path/to/vasp_tier1/scripts"  # VASP reference-force tooling (raddmg vasp_forces)

# ===== Optional external workspaces (cross-model comparison / provenance) ===
# Leave unset unless reproducing the cross-architecture / fine-tune comparisons.
export ZBL_IAML_WS=""              # parent research workspace (a few compare_* scripts)
export ZBL_DPA_WS=""               # external DPA anchor workspace (LAMMPS dpa-anchor mode)
export ZBL_DPA_ANCHOR_WS=""        # external DPA-anchor scripts (fused_dpa_proto)
export ZBL_M3GNET_WS=""            # M3GNet comparison workspace
export ZBL_CHGNET_WS=""            # CHGNet comparison workspace
export ZBL_CRACK_ANALYSIS_WS=""    # matbench crack_analysis (bench_mechanical_stability)
export ZBL_FT_MODELS_WS=""         # fine-tuned-model directory (anchor-vs-FT comparisons)

# ===== Interpreters / build (shell & SLURM drivers) ========================
export ZBL_PYTHON="python"                 # default interpreter (activate the right conda env first)
export ZBL_PYTHON_MACE="python"            # MACE/cuEq-enabled interpreter (LAMMPS fast path)
export ZBL_DEEPMD_PYTHON="python"          # DeepMD-enabled interpreter (LAMMPS native DPA path)
export ZBL_CONDA_BIN="/path/to/conda/env/bin"     # conda env bin/ prepended to PATH (some launchers)
export ZBL_CONDA_ENV="/path/to/conda-env"         # conda env prefix (LD_LIBRARY_PATH / plugins)
export ZBL_DEEPMD_SRC="/path/to/deepmd-kit-src"   # DeePMD-kit source (LAMMPS build helper)
export ZBL_DP_DEVEL_VENV="/path/to/dp-devel-venv" # dev venv for build_dp_devel.sh

# ===== Repo-local directories (auto-derivable; override if needed) =========
export ZBL_BENCH_DIR="/path/to/ZBL_anchored/benchmarks"
export ZBL_LMP_DIR="/path/to/ZBL_anchored/lammps"

# ===== SLURM ================================================================
export ZBL_SLURM_PARTITION="main"          # cluster-specific partition for *.sbatch launchers
