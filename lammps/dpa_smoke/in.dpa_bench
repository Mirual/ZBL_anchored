# DPA-3.1 bench: NVE 200 steps, timing ms/step
units         metal
boundary      p p p
atom_style    atomic
read_data     data_cu256.lammps

pair_style    deepmd /path/to/dpa-3.1-3m-ft.pth
pair_coeff    * * Cu

velocity      all create 300.0 4928459 mom yes rot yes dist gaussian
fix           1 all nve
timestep      0.001
thermo        50

run 200
